rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
