rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /products/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
